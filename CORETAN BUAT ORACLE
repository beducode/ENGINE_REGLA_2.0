---- CEK TABLESPACE
SELECT 
    df.tablespace_name,
    ROUND(SUM(df.bytes) / 1024 / 1024, 2) AS total_mb,
    ROUND(SUM(fs.bytes) / 1024 / 1024, 2) AS free_mb,
    ROUND((SUM(df.bytes) - SUM(fs.bytes)) / 1024 / 1024, 2) AS used_mb
FROM 
    dba_data_files df
LEFT JOIN 
    dba_free_space fs 
ON 
    df.tablespace_name = fs.tablespace_name
GROUP BY 
    df.tablespace_name
ORDER BY 
    df.tablespace_name;

